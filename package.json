{
  "name": "kiezquiz-app",
  "version": "1.0.0",
  "description": "Native iOS/iPadOS/macOS wrapper for KiezQuiz (Capacitor)",
  "private": true,
  "scripts": {
    "sync:web": "node scripts/sync-web.mjs",
    "cap:sync": "npm run sync:web && npx cap sync",
